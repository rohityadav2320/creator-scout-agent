# Supabase credentials for Creator Scout.
# 1. Copy this file to:  .streamlit/secrets.toml   (remove the .example)
# 2. Paste your project URL and API key from the Supabase dashboard
#    (Project Settings -> API). Use the "service_role" key for writing.
# 3. NEVER commit the real secrets.toml to git.
#
# On Streamlit Cloud / other hosts, set these as environment variables instead:
#    SUPABASE_URL  and  SUPABASE_KEY

supabase_url = "https://YOUR-PROJECT-ref.supabase.co"
supabase_key = "YOUR-SERVICE-ROLE-KEY"
